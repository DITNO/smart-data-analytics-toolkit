# Virtual environment
.venv/
venv/
env/

# Python cache
__pycache__/
*.pyc
*.pyo

# Distribution / packaging
build/
dist/
*.egg-info/

# Logs
logs/
*.log

# Data (raw/processed datasets often shouldn't live in git)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Reports/generated output
reports/*
!reports/.gitkeep

# Environment / secrets
.env

# OS/editor junk
.DS_Store
.idea/
.vscode/
